# ─── データベース（MySQL）────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=career_ladder

# ─── JWT ─────────────────────────────────────────────────────────────────────
# 本番では必ず強力なランダム文字列に変更してください
JWT_SECRET=dev-secret-change-in-production

# ─── サーバー ─────────────────────────────────────────────────────────────────
PORT=4000

# ─── OpenAI（任意）───────────────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here
